# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.

# =====
# Theme
# =====
theme = Rose Pine Moon
background-opacity = 0.75
font-family = JetBrainsMono NFM
font-size = 12


# ========
# Keybinds
# ========

# keybind = ctrl+t=new_tab
# keybind = ctrl+w=close_tab
# keybind = ctrl+shift+page_down=move_tab:1
# keybind = ctrl+shift+page_up=move_tab:-1

keybind = ctrl+t=unbind
keybind = ctrl+w=unbind
keybind = ctrl+shift+page_down=unbind
keybind = ctrl+shift+page_up=unbind


# ====
# Misc
# ====
confirm-close-surface = false
resize-overlay = never
